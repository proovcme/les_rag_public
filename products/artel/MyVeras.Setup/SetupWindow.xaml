<Window x:Class="MyVeras.Setup.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MyVeras AI Rendering - Установка" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FF2D2D30">
    
    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#FF007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                BorderThickness="1"
                                BorderBrush="#FF555555">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1E90FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF0066CC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#FF555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBlock" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FF252526" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <Image Source="Resources/icon.png" Width="48" Height="48" Margin="0,0,15,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="MyVeras AI Rendering" FontSize="24" FontWeight="Bold" 
                              Foreground="White"/>
                    <TextBlock Text="Установщик плагина для Revit 2025" FontSize="14" 
                              Foreground="#FFCCCCCC" Margin="0,5,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Welcome Text -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Style="{StaticResource ModernTextBlock}" FontSize="16" FontWeight="Medium" 
                          Text="Добро пожаловать в установщик MyVeras!"/>
                <TextBlock Style="{StaticResource ModernTextBlock}" FontSize="12" 
                          TextWrapping="Wrap" Margin="0,10,0,0"
                          Text="Этот установщик настроит плагин MyVeras AI Rendering для работы с Autodesk Revit 2025. 
                          Плагин поддерживает локальную и облачную генерацию изображений с помощью ИИ."/>
            </StackPanel>

            <!-- Installation Steps -->
            <Border Grid.Row="1" Background="#FF3C3C3C" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Style="{StaticResource ModernTextBlock}" FontSize="14" FontWeight="Medium" 
                              Text="Процесс установки:" Margin="0,0,0,15"/>
                    
                    <StackPanel x:Name="InstallationSteps">
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <Ellipse x:Name="Step1Indicator" Width="16" Height="16" Fill="#FF555555" Margin="0,0,10,0"/>
                            <TextBlock Style="{StaticResource ModernTextBlock}" Text="1. Проверка системы"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <Ellipse x:Name="Step2Indicator" Width="16" Height="16" Fill="#FF555555" Margin="0,0,10,0"/>
                            <TextBlock Style="{StaticResource ModernTextBlock}" Text="2. Поиск Revit 2025"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <Ellipse x:Name="Step3Indicator" Width="16" Height="16" Fill="#FF555555" Margin="0,0,10,0"/>
                            <TextBlock Style="{StaticResource ModernTextBlock}" Text="3. Копирование файлов"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <Ellipse x:Name="Step4Indicator" Width="16" Height="16" Fill="#FF555555" Margin="0,0,10,0"/>
                            <TextBlock Style="{StaticResource ModernTextBlock}" Text="4. Регистрация плагина"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Progress Bar -->
                    <ProgressBar x:Name="InstallationProgress" Height="4" Margin="0,20,0,0" 
                                Background="#FF252526" Foreground="#FF007ACC"/>
                    
                    <!-- Status Text -->
                    <TextBlock x:Name="StatusText" Style="{StaticResource ModernTextBlock}" 
                              FontSize="12" Margin="0,10,0,0" Text="Готов к установке"/>
                </StackPanel>
            </Border>

            <!-- System Info -->
            <Border Grid.Row="2" Background="#FF3C3C3C" CornerRadius="8" Padding="15" Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource ModernTextBlock}" FontSize="12" FontWeight="Medium" 
                              Text="Системная информация:" Margin="0,0,0,10"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource ModernTextBlock}" 
                                  Text="Revit 2025:" Margin="0,2,10,2"/>
                        <TextBlock x:Name="RevitStatusText" Grid.Row="0" Grid.Column="1" 
                                  Style="{StaticResource ModernTextBlock}" Text="Проверка..." 
                                  Foreground="#FFCCCCCC"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource ModernTextBlock}" 
                                  Text="Путь установки:" Margin="0,2,10,2"/>
                        <TextBlock x:Name="InstallPathText" Grid.Row="1" Grid.Column="1" 
                                  Style="{StaticResource ModernTextBlock}" Text="Определение..." 
                                  Foreground="#FFCCCCCC"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource ModernTextBlock}" 
                                  Text="Версия:" Margin="0,2,10,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource ModernTextBlock}" 
                                  Text="1.0.0.0" Foreground="#FFCCCCCC"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="CancelButton" Content="Отмена" Style="{StaticResource ModernButton}" 
                   Background="#FFD32F2F" Margin="0,0,10,0" Click="CancelButton_Click"/>
            <Button x:Name="InstallButton" Content="Установить" Style="{StaticResource ModernButton}" 
                   Click="InstallButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
