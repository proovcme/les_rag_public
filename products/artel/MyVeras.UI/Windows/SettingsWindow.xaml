<Window x:Class="MyVeras.UI.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:MyVeras.UI.Converters"
        Title="MyVeras Settings" Width="500" MinHeight="400"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/MyVeras.UI;component/Resources/icon.png">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="GenAPI Settings" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                
                <TextBlock Text="API Type:" FontWeight="Bold" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <RadioButton Name="CloudApiRadio" Content="Cloud API" IsChecked="True" Margin="0,0,20,0" Checked="ApiType_Changed"/>
                    <RadioButton Name="LocalApiRadio" Content="Local API (Ollama/SD)" IsChecked="False" Margin="0,0,0,0" Checked="ApiType_Changed"/>
                </StackPanel>
                
                <TextBlock Text="API Key:" FontWeight="Bold" Margin="0,0,0,5"
                          Visibility="{Binding ElementName=CloudApiRadio, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <TextBox Name="ApiKeyPasswordBox" Height="30" Margin="0,0,0,15"
                         Visibility="{Binding ElementName=CloudApiRadio, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                
                <TextBlock Text="Local API URL:" FontWeight="Bold" Margin="0,0,0,5"
                          Visibility="{Binding ElementName=LocalApiRadio, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <TextBox Name="LocalApiUrlTextBox" Height="30" Margin="0,0,0,15" IsEnabled="False"
                         Visibility="{Binding ElementName=LocalApiRadio, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                
                <!-- Advanced API Settings -->
                <Expander Header="Advanced API Settings" Margin="0,10,0,10"
                          Visibility="{Binding ElementName=CloudApiRadio, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="Base URL:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Name="ApiBaseUrlTextBox" Height="25" Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Generate Endpoint:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Name="EndpointGenerateTextBox" Height="25" Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Status Endpoint:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Name="EndpointStatusTextBox" Height="25" Margin="0,0,0,10"/>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Name="TestButton" Content="Test Connection" Width="120" Margin="0,0,10,0" Click="TestButton_Click"/>
            <Button Name="SaveButton" Content="Save" Width="80" Margin="0,0,10,0" Click="SaveButton_Click"/>
            <Button Name="CancelButton" Content="Cancel" Width="80" Click="CancelButton_Click"/>
        </StackPanel>
        
        <TextBlock Grid.Row="1" Name="StatusText" Text="" Margin="0,5,0,0" FontSize="12" HorizontalAlignment="Center"/>
    </Grid>
</Window>
