<Window x:Class="MyVeras.UI.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MyVeras AI Rendering" Height="800" Width="950"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/MyVeras.UI;component/Resources/icon.png">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Верхняя панель: Выбор вида и опции -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Левая колонка - Выбор вида -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Select View:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox Name="ViewComboBox" Height="30" />
                </StackPanel>
                
                <!-- Правая колонка - Опции чистки -->
                <StackPanel Grid.Column="2">
                    <CheckBox Name="HideAnnotationsCheck" Content="Скрыть оси, уровни и размеры" 
                             IsChecked="True" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Text="Сила промпта (Guidance Scale):" FontWeight="Bold" Margin="0,5,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" Name="ControlNetStrengthSlider" 
                                Minimum="1.0" Maximum="15.0" Value="5.0" 
                                TickFrequency="0.5" IsSnapToTickEnabled="True" 
                                Margin="0,0,10,0"
                                ValueChanged="ControlNetStrengthSlider_ValueChanged"/>
                        <TextBlock Grid.Column="1" Name="ControlNetStrengthText" 
                                  Text="5.0" Width="40" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </StackPanel>
        
        <!-- Центр: Два изображения для сравнения -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Оригинальный вид -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Original View" FontWeight="Bold" 
                              HorizontalAlignment="Center" Margin="0,5" Foreground="DarkBlue"/>
                    <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" Margin="5">
                        <Grid>
                            <TextBlock Name="SourcePlaceholderTextBlock" Text="Original view will appear here" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center" 
                                      Foreground="Gray" FontSize="14"/>
                            <Image Name="SourcePreviewImage" Stretch="Uniform" Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Результат AI генерации -->
            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="AI Generation Result" FontWeight="Bold" 
                              HorizontalAlignment="Center" Margin="0,5" Foreground="DarkGreen"/>
                    <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" Margin="5">
                        <Grid>
                            <TextBlock Name="PlaceholderTextBlock" Text="Generated image will appear here" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center" 
                                      Foreground="Gray" FontSize="14"/>
                            <Image Name="GeneratedImage" Stretch="Uniform" Visibility="Collapsed"/>
                            <ProgressBar Name="GenerationProgressBar" Height="10" VerticalAlignment="Bottom" 
                                       Visibility="Collapsed" Margin="10"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Нижняя панель: Управление генерацией -->
        <StackPanel Grid.Row="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Prompt -->
                <TextBlock Grid.Column="0" Grid.Row="0" Text="Prompt:" FontWeight="Bold" Margin="0,0,10,5"/>
                <TextBlock Grid.Column="1" Grid.Row="0" Text="Negative Prompt:" FontWeight="Bold" Margin="10,0,0,5"/>
                
                <TextBox Grid.Column="0" Grid.Row="1" Name="PromptTextBox" Height="60" 
                        Text="{Binding UserPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" Margin="0,0,10,15" VerticalScrollBarVisibility="Auto"/>
                <TextBox Grid.Column="1" Grid.Row="1" Name="NegativePromptTextBox" Height="60" 
                        Text="{Binding NegativePrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" Margin="10,0,0,15" VerticalScrollBarVisibility="Auto"/>
                
                <!-- Reference Image Block -->
                <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" 
                        BorderBrush="LightGray" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Column="0" Grid.Row="0" Text="Reference Image:" FontWeight="Bold" Margin="0,0,10,5"/>
                        <Button Grid.Column="1" Grid.Row="0" Name="LoadReferenceButton" Content="📁 Load Reference" 
                                Width="140" Height="30" Margin="0,0,10,5" Click="LoadReferenceButton_Click"/>
                        <Button Grid.Column="2" Grid.Row="0" Name="ClearReferenceButton" Content="🗑️ Clear" 
                                Width="80" Height="30" Margin="0,0,10,5" Click="ClearReferenceButton_Click"/>
                        <TextBlock Grid.Column="3" Grid.Row="0" Name="ReferenceFileNameTextBlock" Text="No reference loaded" 
                                  VerticalAlignment="Center" Margin="10,0,0,5" Foreground="Gray"/>
                        
                        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" 
                                BorderBrush="LightGray" BorderThickness="1" Width="100" Height="100" 
                                HorizontalAlignment="Left" Margin="0,10,0,0">
                            <Grid>
                                <Image Name="ReferencePreviewImage" Stretch="Uniform" 
                                       Visibility="Collapsed" Width="96" Height="96" Margin="2"/>
                                <TextBlock Name="ReferencePlaceholderText" Text="No reference" 
                                          HorizontalAlignment="Center" VerticalAlignment="Center" 
                                          Foreground="Gray" FontSize="12"/>
                            </Grid>
                        </Border>
                        
                        <StackPanel Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="1" 
                                  Orientation="Vertical" Margin="110,10,0,0">
                            <TextBlock Text="Reference Influence:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0" Name="ReferenceInfluenceSlider" 
                                        Minimum="0.1" Maximum="1.0" Value="0.75" 
                                        TickFrequency="0.1" IsSnapToTickEnabled="True" 
                                        Margin="0,0,10,0"
                                        ValueChanged="ReferenceInfluenceSlider_ValueChanged"/>
                                <TextBlock Grid.Column="1" Name="ReferenceInfluenceText" 
                                          Text="0.75" Width="40" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Кнопки -->
                <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="4" 
                           Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Name="CaptureButton" Content="📸 CAPTURE" Width="150" Height="40" 
                           Margin="0,0,20,0" FontWeight="Bold" Click="CaptureButton_Click"/>
                    <Button Name="GenerateButton" Content="🚀 GENERATE" Width="150" Height="40" 
                           Margin="0,0,20,0" FontWeight="Bold" Click="GenerateButton_Click"/>
                    <Button Name="StopButton" Content="🛑 STOP" Width="100" Height="40" 
                           Margin="0,0,20,0" FontWeight="Bold" Click="StopButton_Click" IsEnabled="False"/>
                    <Button Name="ExportButton" Content="EXPORT" Width="100" Height="40" 
                           IsEnabled="False" Click="ExportButton_Click"/>
                </StackPanel>
                
                <!-- Debug Log Expander -->
                <Expander Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="5" Header="Debug Log" Margin="0,15,0,0">
                    <TextBox Name="DebugLogTextBox" 
                             Text="{Binding LogContent}" 
                             IsReadOnly="True" 
                             VerticalScrollBarVisibility="Auto" 
                             Height="150" 
                             Background="Black" 
                             Foreground="Lime"
                             FontFamily="Consolas"
                             FontSize="11"
                             Padding="5"/>
                </Expander>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
