<Window x:Class="MyVeras.UI.Windows.SelectViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select 3D View" Height="300" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Select 3D View:" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <ListBox Grid.Row="1" Name="ViewsListBox" Margin="0,0,0,20"/>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="SelectButton" Content="Select" Width="80" Margin="0,0,10,0" Click="SelectButton_Click"/>
            <Button Name="CancelButton" Content="Cancel" Width="80" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
