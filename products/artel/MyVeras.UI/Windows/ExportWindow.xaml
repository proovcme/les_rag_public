<Window x:Class="MyVeras.UI.Windows.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Image" Height="150" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Click 'Browse' to select export location:" Margin="0,0,0,20"/>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Name="BrowseButton" Content="Browse" Width="80" Margin="0,0,20,0" Click="BrowseButton_Click"/>
            <TextBlock Name="PathTextBlock" Text="No location selected" VerticalAlignment="Center"/>
        </StackPanel>
        
        <Button Grid.Row="2" Name="ExportButton" Content="Export Image" Width="120" Height="30" 
                HorizontalAlignment="Center" Margin="0,20,0,0" Click="ExportButton_Click"/>
    </Grid>
</Window>
