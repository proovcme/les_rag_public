# ── MLX Native Host (Mac Mini) ──────────────────────────────────
LLM_MODEL=mlx-community/Qwen3-14B-4bit
EMBED_MODEL=bge-m3
OLLAMA_URL=http://10.195.146.98:8080

# ── Qdrant (Mac Mini) ───────────────────────────────────────────
QDRANT_URL=http://10.195.146.98:6333

# ── Безопасность ────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME
ADMIN_PASSWORD=CHANGE_ME

# ── Откат на SSH tunnel (если ZeroTier недоступен) ──────────────
