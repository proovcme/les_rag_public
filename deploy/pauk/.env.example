# Л.Е.С. v2 — конфигурация VPS (П.А.У.К.)
# Транспорт: ZeroTier mesh (10.195.146.0/24)
# Mac Mini (Ж.А.Б.А.) ZeroTier IP: 10.195.146.98

# ── MLX Native Host (Mac Mini) ──────────────────────────────────
LLM_MODEL=mlx-community/Qwen3-14B-4bit
EMBED_MODEL=bge-m3
MLX_URL=http://10.195.146.98:8080

# ── Qdrant (Mac Mini) ───────────────────────────────────────────
QDRANT_URL=http://10.195.146.98:6333

# ── Безопасность ────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME
ADMIN_PASSWORD=CHANGE_ME
TRUSTED_NETWORKS=127.0.0.0/8,::1/128,10.195.146.0/24
TRUSTED_NETWORK_ROLE=admin
SOVUSHKA_STORAGE_SECRET=CHANGE_ME_RANDOM_32CHARS

# ── Откат на SSH tunnel (если ZeroTier недоступен) ──────────────
# Запустить tunnel: launchctl load ~/Library/LaunchAgents/me.ovc.les.pauk.plist (на Mac Mini)
# Затем заменить IP на 127.0.0.1:
# MLX_URL=http://127.0.0.1:8080
# QDRANT_URL=http://127.0.0.1:6333
