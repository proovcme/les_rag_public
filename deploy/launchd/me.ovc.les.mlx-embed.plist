<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>me.ovc.les.mlx-embed</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/ovc/LES/.venv/bin/python3</string>
        <string>/Users/ovc/LES/mlx_host.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/ovc/LES</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>MLX_PORT</key>
        <string>8081</string>
        <key>MLX_EMBED_ONLY</key>
        <string>1</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/ovc/LES/logs/mlx_embed.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/ovc/LES/logs/mlx_embed.log</string>

    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>
