<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>С.О.В.У.Ш.К.А. v2.1 | Л.Е.С.</title>
    <style>
        :root {
            --bg-primary: #0f172a; --bg-secondary: #1e293b; --bg-card: #334155;
            --text-primary: #f8fafc; --text-secondary: #94a3b8;
            --accent: #38bdf8; --success: #22c55e; --warning: #eab308; --danger: #ef4444;
            --border: #475569;
        }
        body.light {
            --bg-primary: #f1f5f9; --bg-secondary: #e2e8f0; --bg-card: #ffffff;
            --text-primary: #0f172a; --text-secondary: #64748b;
            --accent: #0284c7; --border: #cbd5e1;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: var(--bg-primary); color: var(--text-primary); height: 100vh; display: flex; flex-direction: column; overflow: hidden; }
        
        /* Sticky Header */
        #sticky-header {
            position: sticky; top: 0; z-index: 100; background: var(--bg-secondary);
            border-bottom: 1px solid var(--border); padding: 8px 16px;
            display: flex; gap: 20px; align-items: center; font-size: 0.85rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.2); flex-wrap: wrap;
        }
        .metric-badge { display: flex; align-items: center; gap: 5px; }
        .metric-badge b { color: var(--accent); }
        .status-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
        
        /* Layout */
        .main-container { display: flex; flex: 1; overflow: hidden; }
        .sidebar { width: 220px; background: var(--bg-secondary); border-right: 1px solid var(--border); padding: 16px; display: flex; flex-direction: column; gap: 8px; }
        .nav-btn {
            background: transparent; border: none; color: var(--text-secondary);
            text-align: left; padding: 10px; cursor: pointer; border-radius: 6px;
            font-size: 0.95rem; transition: 0.2s;
        }
        .nav-btn:hover, .nav-btn.active { background: var(--bg-card); color: var(--text-primary); }
        .content-area { flex: 1; padding: 20px; overflow-y: auto; position: relative; }
        
        /* Tabs */
        .tab-content { display: none; animation: fadeIn 0.3s; }
        .tab-content.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        
        /* Cards & Grid */
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px; margin-bottom: 20px; }
        .card { background: var(--bg-card); padding: 16px; border-radius: 8px; border: 1px solid var(--border); }
        .card h3 { font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
        .card .value { font-size: 1.8rem; font-weight: bold; color: var(--text-primary); }
        
        /* CSS Metrics */
        .progress-bar { height: 8px; background: var(--bg-primary); border-radius: 4px; overflow: hidden; margin-top: 8px; }
        .progress-fill { height: 100%; border-radius: 4px; transition: width 0.5s ease; }
        .bar-ollama { background: var(--danger); }
        .bar-system { background: var(--accent); }
        .bar-free { background: var(--success); }
        
        /* Chat */
        .chat-container { display: flex; flex-direction: column; height: 100%; }
        .chat-messages { flex: 1; overflow-y: auto; padding: 10px; display: flex; flex-direction: column; gap: 12px; }
        .msg { max-width: 80%; padding: 12px; border-radius: 12px; line-height: 1.5; }
        .msg.user { align-self: flex-end; background: var(--accent); color: #fff; }
        .msg.bot { align-self: flex-start; background: var(--bg-card); border: 1px solid var(--border); }
        .msg .source { font-size: 0.75rem; color: var(--text-secondary); margin-top: 6px; border-top: 1px solid var(--border); padding-top: 4px; }
        .chat-input-area { display: flex; gap: 10px; padding-top: 10px; border-top: 1px solid var(--border); }
        .chat-input-area input { flex: 1; padding: 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary); }
        .btn { padding: 10px 20px; background: var(--accent); color: #fff; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; }
        .btn:hover { opacity: 0.9; }
        .btn:disabled { opacity: 0.5; cursor: not-allowed; }
        
        /* Logs */
        .log-container { font-family: monospace; font-size: 0.85rem; background: #000; color: #0f0; padding: 10px; height: 400px; overflow-y: auto; border-radius: 6px; }
        .log-entry { margin-bottom: 4px; border-bottom: 1px solid #333; padding-bottom: 2px; }
        .log-time { color: #888; margin-right: 8px; }
        
        /* Table */
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { text-align: left; padding: 8px; border-bottom: 1px solid var(--border); }
        th { color: var(--text-secondary); font-size: 0.85rem; }
        
        /* Typing cursor */
        .typing-cursor::after { content: '▋'; animation: blink 1s step-end infinite; }
        @keyframes blink { 50% { opacity: 0; } }
    </style>
</head>
<body>
    <!-- Sticky Header -->
    <div id="sticky-header">
        <span style="font-weight:bold; color:var(--accent)">🦉 С.О.В.У.Ш.К.А.</span>
        <div class="metric-badge">CPU: <b id="h-cpu">0%</b></div>
        <div class="metric-badge">RAM: <b id="h-ram">0 GB</b></div>
        <div class="metric-badge">Swap: <b id="h-swap">0 MB</b></div>
        <div class="metric-badge">Queue: <b id="h-queue">0</b></div>
        <div class="metric-badge">Net: <b id="h-net">⚪</b></div>
        <div class="metric-badge">HB: <b id="h-hb">⚪</b></div>
        <button onclick="toggleTheme()" style="margin-left:auto; background:none; border:none; cursor:pointer; font-size:1.2rem">🌓</button>
    </div>

    <div class="main-container">
        <!-- Sidebar -->
        <div class="sidebar">
            <button class="nav-btn active" onclick="showTab('overview')">📊 Обзор</button>
            <button class="nav-btn" onclick="showTab('prorab')">🏗 П.Р.О.Р.А.Б.</button>
            <button class="nav-btn" onclick="showTab('chat')">💬 AI Чат</button>
            <button class="nav-btn" onclick="showTab('logs')">📜 Логи</button>
            <button class="nav-btn" onclick="showTab('datasets')">📁 Датасеты</button>
        </div>

        <!-- Content -->
        <div class="content-area">
            <!-- Tab: Overview -->
            <div id="tab-overview" class="tab-content active">
                <h2>Состояние системы</h2>
                <div class="grid">
                    <div class="card"><h3>Статус Л.Е.С.</h3><div class="value" id="ov-status">Live</div></div>
                    <div class="card"><h3>Документов</h3><div class="value" id="ov-docs">0</div></div>
                    <div class="card"><h3>Чанков</h3><div class="value" id="ov-chunks">0</div></div>
                    <div class="card"><h3>CRAG Pass Rate</h3><div class="value" id="ov-crag">0%</div></div>
                </div>
                <div class="card">
                    <h3>Последние события</h3>
                    <div id="ov-events" style="font-size:0.9rem; color:var(--text-secondary)">Ожидание данных...</div>
                </div>
            </div>

            <!-- Tab: Prorab -->
            <div id="tab-prorab" class="tab-content">
                <h2>🏗 П.Р.О.Р.А.Б. — Детальные метрики</h2>
                <div class="grid">
                    <div class="card">
                        <h3>RAM Breakdown</h3>
                        <div style="display:flex; justify-content:space-between; font-size:0.8rem; margin-bottom:4px">
                            <span>Ollama: <b id="p-ram-ollama">0</b> GB</span>
                            <span>System: <b id="p-ram-sys">0</b> GB</span>
                            <span>Total: <b id="p-ram-total">0</b> GB</span>
                        </div>
                        <div class="progress-bar" style="display:flex">
                            <div id="bar-ollama" class="progress-fill bar-ollama" style="width:0%"></div>
                            <div id="bar-sys" class="progress-fill bar-system" style="width:0%"></div>
                        </div>
                    </div>
                    <div class="card">
                        <h3>Storage Usage</h3>
                        <div class="value" id="p-disk-val">0 / 0 GB</div>
                        <div class="progress-bar"><div id="bar-disk" class="progress-fill" style="width:0%; background:var(--warning)"></div></div>
                    </div>
                    <div class="card">
                        <h3>Pipeline Latency (avg)</h3>
                        <div style="display:flex; gap:10px; align-items:center">
                            <div>Search: <b id="p-lat-search">0s</b></div>
                            <div>Gen: <b id="p-lat-gen">0s</b></div>
                        </div>
                        <div class="progress-bar" style="display:flex; margin-top:8px">
                            <div id="bar-lat-search" class="progress-fill" style="width:0%; background:var(--accent)"></div>
                            <div id="bar-lat-gen" class="progress-fill" style="width:0%; background:var(--danger)"></div>
                        </div>
                    </div>
                    <div class="card">
                        <h3>Token Usage</h3>
                        <div class="value" id="p-tokens">0</div>
                        <div class="progress-bar"><div id="bar-tokens" class="progress-fill" style="width:0%; background:var(--accent)"></div></div>
                        <div style="font-size:0.75rem; color:var(--text-secondary); margin-top:4px">Limit: 8192</div>
                    </div>
                </div>
                <div class="card">
                    <h3>Background Tasks Health</h3>
                    <table>
                        <tr><th>Task</th><th>Status</th><th>Last Beat</th></tr>
                        <tr><td>Metrics Collector</td><td id="hb-col-status">⚪</td><td id="hb-col-time">-</td></tr>
                        <tr><td>SSE Emitter</td><td id="hb-sse-status">⚪</td><td id="hb-sse-time">-</td></tr>
                        <tr><td>Folder Watcher</td><td id="hb-watch-status">⚪</td><td id="hb-watch-time">-</td></tr>
                    </table>
                </div>
            </div>

            <!-- Tab: Chat -->
            <div id="tab-chat" class="tab-content">
                <div class="chat-container">
                    <div id="chat-messages" class="chat-messages"></div>
                    <div class="chat-input-area">
                        <input type="text" id="chat-input" placeholder="Задайте вопрос по нормативам..." onkeydown="if(event.key==='Enter')sendChat()">
                        <button class="btn" id="chat-send-btn" onclick="sendChat()">ОТПРАВИТЬ</button>
                    </div>
                </div>
            </div>

            <!-- Tab: Logs -->
            <div id="tab-logs" class="tab-content">
                <h2>Системные логи (SSE)</h2>
                <div id="log-container" class="log-container"></div>
            </div>

            <!-- Tab: Datasets -->
            <div id="tab-datasets" class="tab-content">
                <h2>Управление датасетами</h2>
                <button class="btn" onclick="loadDatasets()" style="margin-bottom:10px">🔄 Обновить</button>
                <table id="datasets-table">
                    <thead><tr><th>Источник</th><th>Файлов</th><th>Статус</th><th>Действие</th></tr></thead>
                    <tbody id="datasets-body"><tr><td colspan="4">Загрузка...</td></tr></tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // --- State & Config ---
        const API_BASE = '';
        let sseSource = null;
        
        // --- UI Navigation ---
        function showTab(id) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.nav-btn').forEach(el => el.classList.remove('active'));
            document.getElementById('tab-' + id).classList.add('active');
            // Highlight button
            const btns = document.querySelectorAll('.nav-btn');
            const map = {overview:0, prorab:1, chat:2, logs:3, datasets:4};
            if(map[id] !== undefined) btns[map[id]].classList.add('active');
            
            if (id === 'datasets') loadDatasets();
            if (id === 'logs' && !sseSource) connectSSE();
        }

        function toggleTheme() {
            document.body.classList.toggle('light');
        }

        // --- Metrics Bridge ---
        async function fetchMetrics() {
            try {
                const res = await fetch(API_BASE + '/api/metrics');
                if (!res.ok) return;
                const data = await res.json();
                const s = data.system || {};
                const p = data.pipeline || {};
                const q = data.queue || {};
                const hb = data.heartbeats || {};

                // Sticky Header
                document.getElementById('h-cpu').innerText = (s.cpu||0).toFixed(1) + '%';
                document.getElementById('h-ram').innerText = (s.ram_used||0).toFixed(1) + '/' + (s.ram_total||0).toFixed(1) + ' GB';
                
                const swapMB = (s.swap_used||0) * 1000;
                const swapEl = document.getElementById('h-swap');
                swapEl.innerText = swapMB.toFixed(0) + ' MB';
                swapEl.style.color = swapMB > 100 ? 'var(--danger)' : 'var(--success)';

                document.getElementById('h-queue').innerText = q.llm_waiting || 0;
                document.getElementById('h-net').innerText = s.network_ok === 2 ? '✅' : '⚠️';
                
                const now = Date.now() / 1000;
                const hbEl = document.getElementById('h-hb');
                hbEl.innerText = (now - (hb.collector||0) < 10) ? '🟢' : '🔴';

                // Overview Tab
                document.getElementById('ov-crag').innerText = ((p.crag_pass_rate||0)*100).toFixed(0) + '%';

                // Prorab Tab
                // RAM
                const ramOllama = s.ollama_ram || 0;
                const ramSys = (s.ram_used || 0) - ramOllama;
                const ramTotal = s.ram_total || 1;
                document.getElementById('p-ram-ollama').innerText = ramOllama.toFixed(1);
                document.getElementById('p-ram-sys').innerText = ramSys.toFixed(1);
                document.getElementById('p-ram-total').innerText = ramTotal.toFixed(1);
                document.getElementById('bar-ollama').style.width = (ramOllama/ramTotal*100) + '%';
                document.getElementById('bar-sys').style.width = (ramSys/ramTotal*100) + '%';

                // Disk
                const diskUsed = s.disk_used || 0;
                const diskTotal = s.disk_total || 1;
                document.getElementById('p-disk-val').innerText = (diskUsed/1000).toFixed(1) + ' / ' + (diskTotal/1000).toFixed(1) + ' TB';
                document.getElementById('bar-disk').style.width = (diskUsed/diskTotal*100) + '%';

                // Latency
                const latSearch = p.latency_search?.length ? p.latency_search[p.latency_search.length-1] : 0;
                const latGen = p.latency_gen?.length ? p.latency_gen[p.latency_gen.length-1] : 0;
                document.getElementById('p-lat-search').innerText = latSearch.toFixed(2) + 's';
                document.getElementById('p-lat-gen').innerText = latGen.toFixed(2) + 's';
                const maxLat = 5; // scale
                document.getElementById('bar-lat-search').style.width = Math.min(100, latSearch/maxLat*100) + '%';
                document.getElementById('bar-lat-gen').style.width = Math.min(100, latGen/maxLat*100) + '%';

                // Tokens
                const tokens = p.tokens?.length ? p.tokens[p.tokens.length-1] : 0;
                document.getElementById('p-tokens').innerText = tokens;
                document.getElementById('bar-tokens').style.width = Math.min(100, tokens/8192*100) + '%';

                // Heartbeats
                const updateHB = (id, time) => {
                    const elStatus = document.getElementById(id + '-status');
                    const elTime = document.getElementById(id + '-time');
                    const diff = now - time;
                    elStatus.innerText = diff < 10 ? '🟢 Alive' : '🔴 Dead';
                    elTime.innerText = new Date(time*1000).toLocaleTimeString();
                };
                updateHB('hb-col', hb.collector||0);
                updateHB('hb-sse', hb.sse_emitter||0);
                updateHB('hb-watch', hb.folder_watcher||0);

            } catch(e) { console.warn('Metrics error', e); }
        }

        // --- Chat Logic ---
        async function sendChat() {
            const input = document.getElementById('chat-input');
            const query = input.value.trim();
            if (!query) return;
            
            input.value = '';
            const msgContainer = document.getElementById('chat-messages');
            
            // User Msg
            const userDiv = document.createElement('div');
            userDiv.className = 'msg user';
            userDiv.innerText = query;
            msgContainer.appendChild(userDiv);
            
            // Bot Placeholder
            const botDiv = document.createElement('div');
            botDiv.className = 'msg bot';
            botDiv.innerHTML = '<span class="typing-cursor">Думаю...</span>';
            msgContainer.appendChild(botDiv);
            msgContainer.scrollTop = msgContainer.scrollHeight;
            
            document.getElementById('chat-send-btn').disabled = true;
            
            try {
                const res = await fetch(API_BASE + '/api/chat', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ query: query })
                });
                const data = await res.json();
                const answer = data.answer || data.response || 'Нет ответа';
                const sources = data.sources || [];
                
                // Typewriter Effect
                botDiv.innerHTML = '';
                let i = 0;
                const typeInterval = setInterval(() => {
                    botDiv.innerHTML += answer.charAt(i);
                    i++;
                    msgContainer.scrollTop = msgContainer.scrollHeight;
                    if (i >= answer.length) {
                        clearInterval(typeInterval);
                        botDiv.classList.remove('typing-cursor');
                        // Add Sources
                        if (sources.length > 0) {
                            const srcDiv = document.createElement('div');
                            srcDiv.className = 'source';
                            srcDiv.innerHTML = '📚 Источники: ' + sources.slice(0, 3).map(s => `<b>${s.file || s}</b>`).join(', ');
                            botDiv.appendChild(srcDiv);
                        }
                        document.getElementById('chat-send-btn').disabled = false;
                    }
                }, 15); // Speed
                
            } catch(e) {
                botDiv.innerText = 'Ошибка соединения: ' + e.message;
                document.getElementById('chat-send-btn').disabled = false;
            }
        }

        // --- SSE Logs ---
        function connectSSE() {
            const logContainer = document.getElementById('log-container');
            sseSource = new EventSource(API_BASE + '/api/logs/stream');
            sseSource.onmessage = (event) => {
                try {
                    const data = JSON.parse(event.data);
                    const div = document.createElement('div');
                    div.className = 'log-entry';
                    const time = new Date().toLocaleTimeString();
                    div.innerHTML = `<span class="log-time">[${time}]</span> ${data.message || JSON.stringify(data)}`;
                    logContainer.appendChild(div);
                    logContainer.scrollTop = logContainer.scrollHeight;
                } catch(e) {}
            };
            sseSource.onerror = () => {
                logContainer.innerHTML += '<div style="color:red">SSE Connection lost. Retrying...</div>';
            };
        }

        // --- Datasets ---
        async function loadDatasets() {
            const tbody = document.getElementById('datasets-body');
            tbody.innerHTML = '<tr><td colspan="4">Загрузка...</td></tr>';
            try {
                const res = await fetch(API_BASE + '/api/rag/sources');
                const data = await res.json();
                tbody.innerHTML = '';
                if (!data.length) {
                    tbody.innerHTML = '<tr><td colspan="4">Нет источников</td></tr>';
                    return;
                }
                data.forEach(ds => {
                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td>${ds.name}</td>
                        <td>${ds.file_count || 0}</td>
                        <td>${ds.status || 'IDLE'}</td>
                        <td><button class="btn" style="padding:4px 8px; font-size:0.8rem" onclick="syncFolder('${ds.name}')">🔄 Sync</button></td>
                    `;
                    tbody.appendChild(tr);
                });
            } catch(e) {
                tbody.innerHTML = '<tr><td colspan="4" style="color:red">Ошибка загрузки</td></tr>';
            }
        }

        async function syncFolder(name) {
            if(!confirm(`Запустить синхронизацию ${name}?`)) return;
            try {
                const res = await fetch(API_BASE + `/api/rag/sync/${name}`, { method: 'POST' });
                const data = await res.json();
                alert(`Задача запущена: ${data.job_id || 'OK'}`);
                loadDatasets();
            } catch(e) { alert('Ошибка: ' + e.message); }
        }

        // --- Init ---
        setInterval(fetchMetrics, 3000);
        fetchMetrics();
    </script>
</body>
</html>