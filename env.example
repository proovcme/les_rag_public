# Л.Е.С. — конфигурация
# Скопируй в .env и заполни

# ── LLM ──────────────────────────────────────────
# Основная модель (MLX). Safe default для Apple Silicon 24 GB.
MLX_MODEL=mlx-community/Qwen3.5-4B-OptiQ-4bit

# Модель-валидатор Т.О.С.К.А.
MLX_VAL_MODEL=mlx-community/Qwen3-4B-Instruct-2507-4bit

# Для прокси (должен совпадать с MLX_MODEL)
LLM_MODEL=mlx-community/Qwen3.5-4B-OptiQ-4bit

# Quality profile для ручных прогонов на 24+ GB:
# MLX_MODEL=mlx-community/Qwen3-14B-4bit
# LLM_MODEL=mlx-community/Qwen3-14B-4bit

# ── Эмбеддинги ───────────────────────────────────
# Qwen-профиль — текущий recommended default. Не смешивай embedding-модели
# в одной коллекции; для legacy BGE-M3 используй отдельную les_rag.
LES_EMBED_PROFILE=qwen
EMBED_MODEL=qwen3-embedding-0.6b
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# Backward compatibility: если EMBEDDING_MODEL не задан, mlx_host.py читает BGE_MODEL.
BGE_MODEL=BAAI/bge-m3
RAG_COLLECTION_NAME=les_rag_qwen3_06b
RAG_META_DB_PATH=./data/les_meta_qwen.db
RAG_VECTOR_SIZE=1024
BGE_BATCH_SIZE=8
RAG_EMBED_BATCH=8
RAG_CHUNK_SIZE=1400
RAG_CHUNK_OVERLAP=100
RAG_PARSE_POST_MAX_SWAP_PCT=60

# Legacy BGE-M3 profile:
# LES_EMBED_PROFILE=legacy
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBED_MODEL=bge-m3
# RAG_COLLECTION_NAME=les_rag
# RAG_META_DB_PATH=./data/les_meta.db
# RAG_VECTOR_SIZE=1024
# RAG_CHUNK_SIZE=900
# RAG_CHUNK_OVERLAP=80

# ── URLs ─────────────────────────────────────────
# MLX Host для host-proxy. Docker proxy получает override из docker-compose.yml.
MLX_URL=http://127.0.0.1:8080

# Резерв через Ollama
# OLLAMA_URL=http://host.docker.internal:11434
# LLM_MODEL=qwen3:14b
# EMBED_MODEL=bge-m3:latest

# Qdrant local предпочитает host binary ~/.local/bin/qdrant; docker оставлен как fallback.
QDRANT_URL=http://127.0.0.1:6333
LES_QDRANT_RUNTIME=auto

# ── Безопасность ─────────────────────────────────
# JWT секрет (замени на случайную строку)
JWT_SECRET=change_me_to_random_string_32chars

# Пароль admin-ключа для В.О.Л.К.
# После первого запуска создаётся запись в auth_keys
ADMIN_PASSWORD=change_me_to_strong_password

# Trusted networks without API key. Keep loopback by default; add your VPN/LAN CIDR explicitly.
TRUSTED_NETWORKS=127.0.0.0/8,::1/128
TRUSTED_NETWORK_ROLE=admin
TRUSTED_PROXY_NETWORKS=127.0.0.0/8,::1/128
TRUSTED_PROXY_HEADER=x-les-trusted-network
# Example: TRUSTED_NETWORKS=127.0.0.0/8,::1/128,10.0.0.0/24
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8050,http://127.0.0.1:8050,http://localhost:8051,http://127.0.0.1:8051
LES_ENABLE_DOCKER_CONTROL=false
RAG_UPLOAD_SUFFIXES=.pdf,.docx,.doc,.eml,.msg,.xlsx,.xls,.csv,.json,.jsonl,.md,.txt
MAX_UPLOAD_MB=100
MAX_PST_UPLOAD_MB=2048
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.94
PDF_TABLE_EXTRACTION_ENABLED=false
PDF_TABLE_MAX_PAGES=30
PDF_TABLE_MAX_TABLES=50
DOC_ROUTER_SAMPLE_PAGES=3
SOVUSHKA_STORAGE_SECRET=change_me_to_random_string_32chars
