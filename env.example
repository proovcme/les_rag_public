# Л.Е.С. — конфигурация
# Скопируй в .env и заполни

# ── LLM ──────────────────────────────────────────
# Основная модель (MLX). Safe default для Apple Silicon 24 GB.
MLX_MODEL=mlx-community/Qwen3.5-4B-OptiQ-4bit

# Модель-валидатор Т.О.С.К.А.
MLX_VAL_MODEL=mlx-community/Qwen3.5-4B-OptiQ-4bit

# Для прокси (должен совпадать с MLX_MODEL)
LLM_MODEL=mlx-community/Qwen3.5-4B-OptiQ-4bit

# Quality profile для ручных прогонов на 24+ GB:
# MLX_MODEL=mlx-community/Qwen3-14B-4bit
# LLM_MODEL=mlx-community/Qwen3-14B-4bit

# MLX Host hardening: localhost bind по умолчанию, ранний memory guard и
# больший контекст Т.О.С.К.А. вместо старого 1500-symbol snippet.
MLX_HOST_BIND=127.0.0.1
MLX_KEEP_SINGLE_LLM_LOADED=true
MLX_RAM_WARN_FREE_GB=8
MLX_RAM_KILL_FREE_GB=6
MLX_VALIDATE_CONTEXT_CHARS=8000
MLX_VALIDATE_ANSWER_CHARS=1500
MLX_EMBED_TTL_SEC=300

# Validator backend: mlx — текущий рабочий валидатор, coreml — NLI/cross-encoder
# кандидат на Neural Engine, rules — безопасный deterministic fallback для тестов.
VALIDATOR_BACKEND=mlx
VALIDATOR_MODEL_VERSION=main
COREML_VALIDATOR_MODEL=artifacts/coreml/validator_minilm_l6_b1_s512.mlpackage
COREML_VALIDATOR_TOKENIZER=MoritzLaurer/multilingual-MiniLMv2-L6-mnli-xnli
COREML_VALIDATOR_VERSION=MoritzLaurer/multilingual-MiniLMv2-L6-mnli-xnli@validator_minilm_l6_b1_s512.mlpackage
COREML_VALIDATOR_SEQ_LEN=512
COREML_VALIDATOR_ATTENTION_MASK_RANK=4
COREML_VALIDATOR_COMPUTE_UNITS=cpu_only
COREML_VALIDATOR_CONTEXT_MODE=windows
COREML_VALIDATOR_PAIR_MODE=answer
COREML_VALIDATOR_ISOLATE_PROCESS=true
COREML_VALIDATOR_WORKER_TIMEOUT_SEC=60
COREML_VALIDATOR_MAX_FAILURES=2
COREML_VALIDATOR_FAILURE_COOLDOWN_SEC=300
COREML_VALIDATOR_LABELS=entailment,neutral,contradiction
COREML_VALIDATOR_MIN_CONFIDENCE=0.0
COREML_VALIDATOR_ENTAILMENT_THRESHOLD=0.8
COREML_VALIDATOR_CONTRADICTION_THRESHOLD=0.6
COREML_VALIDATOR_DECISION_MARGIN=0.05
COREML_VALIDATOR_LOCAL_FILES_ONLY=true
COREML_VALIDATOR_FALLBACK=false

# ── Эмбеддинги ───────────────────────────────────
# Qwen-профиль — текущий recommended default. Не смешивай embedding-модели
# в одной коллекции; для legacy BGE-M3 используй отдельную les_rag.
LES_EMBED_PROFILE=qwen
EMBED_MODEL=qwen3-embedding-0.6b
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# Backward compatibility: если EMBEDDING_MODEL не задан, mlx_host.py читает BGE_MODEL.
BGE_MODEL=BAAI/bge-m3
RAG_COLLECTION_NAME=les_rag_qwen3_06b
RAG_META_DB_PATH=./data/les_meta_qwen.db
RAG_VECTOR_SIZE=1024
# W2.4: Qdrant-native гибрид — BM25/IDF sparse-сайдкар рядом с dense.
# RAG_SPARSE_ENABLED=true включает sparse-ветку в _hybrid_merge (mode=hybrid+sparse).
# Сайдкар: {RAG_COLLECTION_NAME}_sparse (или явно RAG_SPARSE_COLLECTION).
# Построить: uv run python tools/reindex_sparse_bge_m3.py --recreate
RAG_SPARSE_ENABLED=false
# RAG_SPARSE_COLLECTION=
BGE_BATCH_SIZE=8
# W1.1 (LES3_PLAN): целевые значения после замера на живом рантайме — RAG_EMBED_BATCH=64,
# RAG_UPSERT_BATCH=256. Менять по одному параметру с контролем RAM/латентности.
RAG_EMBED_BATCH=16
RAG_CHUNK_SIZE=1400
RAG_CHUNK_OVERLAP=100
# W1.2: exact-count точек в Qdrant выполняется каждый N-й файл (и для последнего), не после каждого.
RAG_VERIFY_POINTS_EVERY=10
RAG_PARSE_POST_MAX_SWAP_PCT=60

# ── Скан-OCR (сканированные PDF без текстового слоя) ──
# GLM-OCR удалён → дефолтный бэкенд vision-OCR — ollama (gemma4:12b, локальный vision, ADR-9).
# RAG_OCR_BACKEND: tesseract (бинарь, лучший локальный для русского, изолирован) |
#                  ollama (gemma4:12b vision-VLM) | mlx (MLX-VLM на Metal).
# tesseract: brew install tesseract tesseract-lang. Зовётся subprocess'ом → НЕ конфликтует с
# зависимостями venv (transformers 5.x для MLX). RapidOCR не годен (нет кириллицы), Surya 0.20
# требует llama.cpp + ломает transformers — поэтому локальный дефолт-кандидат = tesseract.
RAG_OCR_ENABLED=true
RAG_OCR_BACKEND=tesseract
RAG_OCR_MODEL=gemma4:12b
RAG_OCR_TESSERACT_LANG=rus+eng
RAG_OCR_TESSERACT_DPI=300
RAG_OCR_TESSERACT_PSM=6
# RAG_OCR_TESSERACT_BIN=/opt/homebrew/bin/tesseract   # если не на PATH у launchd
# Нормоконтроль D4-002 (штамп/основная надпись): OCR штампа для СКАНОВ без текст-слоя через тот же
# Tesseract (вне hot-path — OFF по умолчанию; оператор включает на скан-комплект). OCR только
# ПОДТВЕРЖДАЕТ штамп (скан→present); не подтвердил → manual. REGION: br (угол штампа) | full.
LES_TITLE_BLOCK_OCR=0
LES_TITLE_BLOCK_OCR_REGION=br
LES_TITLE_BLOCK_OCR_DPI=300
# Vision-эндпоинт; пусто → берётся OLLAMA_BASE_URL (ниже). Для mlx-бэкенда укажи MLX-VLM модель.
RAG_OCR_URL=
RAG_OCR_DPI=150

# Приёмка смонтированного объёма из исполнительных схем/чек-листов (asbuilt_intake_service).
# Единственный LLM-шаг — vision-OCR ячеек; числа/свод считает код (ADR-11). Строки падают в
# журнал объёмов как status=pending (приёмка → подтверждение). Эндпоинт POST /api/field/extract-asbuilt.
LES_ASBUILT_OCR_ENGINE=local      # local (gemma4:12b, приватно) | cloud (gpt-4.1 через proxyapi)
LES_ASBUILT_CLOUD_MODEL=gpt-4.1   # модель для cloud-движка (иначе OPENAI_MODEL)
LES_ASBUILT_DPI=200               # рендер скана; плотные таблицы лучше читаются на 200+
LES_ASBUILT_MAX_SIDE=0            # даунскейл стороны перед отправкой в vision (0 = без даунскейла)
LES_ASBUILT_OCR_TIMEOUT=180
# Стратегия извлечения: locate (найди таблицу bbox → прочитай целиком, без дублей; дефолт) |
# tiles (сетка фрагментов — фолбэк, если locate ничего не нашёл).
LES_ASBUILT_STRATEGY=locate
LES_ASBUILT_LOCATE_SIDE=1600      # сторона уменьшенного листа для шага локализации
LES_ASBUILT_LOCATE_PAD=0.035      # запас вокруг найденной рамки (доля), чтобы не срезать строки/колонки
LES_ASBUILT_TILES=4x4             # сетка фолбэка RxC
LES_ASBUILT_TILE_OVERLAP=0.3      # перекрытие фрагментов сетки (доля)
# Auto-init при индексации папки: LES.md появляется сам + авто-исполнение директив LES.md
# (ид→asbuilt и т.п.) в фоне, без команды оператора. Off → только ручной разбор «пойми папку».
LES_AUTO_PIPELINES=true
# Ярус 2 — агент-роутер: когда regex-каналы не поймали, LLM сам выбирает инструмент
# (asbuilt/les_md/реестр/объёмы/задачи), исполняет детерминированный обработчик. Числа — код.
# off → только regex-каналы + RAG (старый путь, фолбэк). Включай осознанно.
LES_AGENT_LOOP=false

# Core ML embedding backend. Requires `uv sync --group coreml` and a matching
# fixed-shape .mlpackage generated by tools/coreml_embedding_probe.py. Runtime
# keeps Core ML predict in an isolated worker process so a native CoreML crash
# cannot take down MLX Host. For Qwen b1_s1024, cpu_only returned zero vectors
# and cpu_and_ne crashed; cpu_and_gpu is the current guarded Core ML path.
EMBED_BACKEND=coreml
COREML_EMBED_MODEL=artifacts/coreml/qwen3_embedding_06b_b1_s512_static.mlpackage
COREML_EMBED_SEQ_LEN=512
# ВНИМАНИЕ (W1.1): batch/seq зашиты в fixed-shape .mlpackage (b1_s512). Поднять батч до 4 —
# это регенерация артефакта tools/coreml_embedding_probe.py (b4_s512) + замер, не правка числа.
COREML_EMBED_BATCH_SIZE=1
COREML_EMBED_COMPUTE_UNITS=cpu_and_gpu
COREML_EMBED_ISOLATE_PROCESS=true
COREML_EMBED_WORKER_TIMEOUT_SEC=120
COREML_EMBED_MIN_NORM=0.5
COREML_EMBED_MAX_NORM=1.5
COREML_EMBED_MAX_FAILURES=2
COREML_EMBED_FAILURE_COOLDOWN_SEC=300
COREML_EMBED_LOCAL_FILES_ONLY=true
COREML_EMBED_FALLBACK=true

# Legacy BGE-M3 profile:
# LES_EMBED_PROFILE=legacy
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBED_MODEL=bge-m3
# RAG_COLLECTION_NAME=les_rag
# RAG_META_DB_PATH=./data/les_meta.db
# RAG_VECTOR_SIZE=1024
# RAG_CHUNK_SIZE=900
# RAG_CHUNK_OVERLAP=80

# ── URLs ─────────────────────────────────────────
# MLX Host для host-proxy. Docker proxy получает override из docker-compose.yml.
MLX_URL=http://127.0.0.1:8080

# Chat provider. `mlx` is the Mac/local default. Windows light can use
# `openrouter`, `openai`, `ollama`, `lemonade` or `openai-compatible`.
LES_LLM_PROVIDER=mlx

# External/local OpenAI-compatible providers. API keys are managed from GUI
# settings; keep defaults empty and do not commit real keys.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=
OPENROUTER_API_KEY=

# OpenAI cloud or any generic OpenAI-compatible server.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=
OPENAI_API_KEY=

# Ollama exposes an OpenAI-compatible API under /v1 on recent installs.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
OLLAMA_API_KEY=

# Lemonade Server is OpenAI-compatible. The key is usually required by clients
# but can be a placeholder for local Lemonade.
LEMONADE_BASE_URL=http://127.0.0.1:13305/api/v1
LEMONADE_MODEL=
LEMONADE_API_KEY=lemonade

# --- W3.3 / ADR-9: маршрутизация локал/облако по чувствительности данных ---
# Чувствительность размечается на датасете (P0/P1/P2), дефолт P0 (local-only).
# P0 — никогда в облако; P1 — можно; P2 — только при LES_CLOUD_CONSENT=true.
LES_CLOUD_CONSENT=false
# Переопределение цен облака (за 1M токенов вход/выход): "model:in/out,model2:in/out".
# Пусто — дефолтная таблица из backend/inference/routing.py (GPT-5.5 $5/$30 и т.д.).
LES_CLOUD_PRICES=
# Ниже этого порога свободной RAM локальный конкурент MLX (ollama/lemonade)
# сводится к MLX — защита от swap (полевой вывод: ollama рядом с MLX → swap).
LES_LOCAL_PROVIDER_MIN_FREE_GB=6.0

# Speckle BIM/CAD bridge. Speckle may sleep; LES probes it with a short timeout.
SPECKLE_ENABLED=true
SPECKLE_BASE_URL=https://speckle.ovc.me
SPECKLE_GRAPHQL_URL=https://speckle.ovc.me/graphql
SPECKLE_API_TOKEN=
SPECKLE_WAKE_TIMEOUT_SEC=5

# Legacy Ollama variable, kept for old scripts.
# OLLAMA_URL=http://host.docker.internal:11434

# Qdrant local предпочитает host binary ~/.local/bin/qdrant; docker оставлен как fallback.
QDRANT_URL=http://127.0.0.1:6333
LES_QDRANT_RUNTIME=auto

# ── Безопасность ─────────────────────────────────
# JWT секрет (замени на случайную строку)
JWT_SECRET=change_me_to_random_string_32chars

# Пароль admin-ключа для В.О.Л.К.
# После первого запуска создаётся запись в auth_keys
ADMIN_PASSWORD=change_me_to_strong_password

# Trusted networks without API key. Keep loopback by default; add your VPN/LAN CIDR explicitly.
TRUSTED_NETWORKS=127.0.0.0/8,::1/128
TRUSTED_NETWORK_ROLE=admin
TRUSTED_PROXY_NETWORKS=127.0.0.0/8,::1/128
TRUSTED_PROXY_HEADER=x-les-trusted-network
# Example: TRUSTED_NETWORKS=127.0.0.0/8,::1/128,10.0.0.0/24
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8050,http://127.0.0.1:8050,http://localhost:8051,http://127.0.0.1:8051
LES_ENABLE_DOCKER_CONTROL=false
RAG_UPLOAD_SUFFIXES=.pdf,.docx,.doc,.eml,.emlx,.msg,.xlsx,.xls,.csv,.json,.jsonl,.md,.txt,.dwg,.rvt,.ifc,.ifczip
MAX_UPLOAD_MB=100
MAX_PST_UPLOAD_MB=2048
MAIL_IMAP_HOST=
MAIL_IMAP_PORT=993
MAIL_IMAP_SSL=true
MAIL_IMAP_LOGIN=
MAIL_IMAP_PASSWORD=
MAIL_IMAP_FOLDERS=INBOX
MAIL_IMAP_TIMEOUT_SEC=45
MAIL_IMAP_CHECKPOINT_DIR=data/mail_imap_checkpoints
MAIL_IMAP_STORAGE_ROOT=RAG_Content/MAIL/IMAP
MAIL_APPLE_ROOT=~/Library/Mail
MAIL_APPLE_STORAGE_ROOT=RAG_Content/MAIL/AppleMail
MAIL_ATTACHMENT_PDF_SUBPROCESS_ENABLED=true
MAIL_ATTACHMENT_PDF_TIMEOUT_SEC=30
MAIL_ATTACHMENT_PDF_MAX_PAGES=20
MAIL_ATTACHMENT_OCR_ENABLED=true
MAIL_TESSERACT_BIN=tesseract
MAIL_OCR_LANG=rus+eng
MAIL_ATTACHMENT_VLM_ENABLED=false
MAIL_VLM_URL=
MAIL_VLM_MODEL=
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.94
PDF_TABLE_EXTRACTION_ENABLED=false
PDF_TABLE_MAX_PAGES=30
PDF_TABLE_MAX_TABLES=50
DOCX_TABLE_EXTRACTION_ENABLED=false
DOCX_TABLE_MAX_TABLES=80
DOC_ROUTER_SAMPLE_PAGES=3
SOVUSHKA_STORAGE_SECRET=change_me_to_random_string_32chars

# ADR-12: типизированный двухстадийный ретрив (стадия-1 LLM-роутер по каталогу
# документов + кэш в doc_router_cache, стадия-2 поиск со scope-фильтром). Пусто/false
# → прежний плоский поиск. Роутер ходит в LES_LLM_PROVIDER, таймаут LES_ROUTER_TIMEOUT_SEC.
LES_TYPED_RETRIEVAL=false

# Индексация: порог свободной RAM (дефолт 8 конфликтует с 9B-моделью → блок парса)
# и размер батча дренажа очереди PENDING на один upload.
RAG_PARSE_MIN_FREE_GB=4
LES_UPLOAD_PARSE_LIMIT=25
