# Л.Е.С. — конфигурация
# Скопируй в .env и заполни

# ── LLM ──────────────────────────────────────────
# Основная модель (MLX). Safe default для Apple Silicon 24 GB.
MLX_MODEL=mlx-community/Qwen3.5-4B-OptiQ-4bit

# Модель-валидатор Т.О.С.К.А.
MLX_VAL_MODEL=mlx-community/Qwen3.5-4B-OptiQ-4bit

# Для прокси (должен совпадать с MLX_MODEL)
LLM_MODEL=mlx-community/Qwen3.5-4B-OptiQ-4bit

# Quality profile для ручных прогонов на 24+ GB:
# MLX_MODEL=mlx-community/Qwen3-14B-4bit
# LLM_MODEL=mlx-community/Qwen3-14B-4bit

# MLX Host hardening: localhost bind по умолчанию, ранний memory guard и
# больший контекст Т.О.С.К.А. вместо старого 1500-symbol snippet.
MLX_HOST_BIND=127.0.0.1
MLX_KEEP_SINGLE_LLM_LOADED=true
MLX_RAM_WARN_FREE_GB=8
MLX_RAM_KILL_FREE_GB=6
MLX_VALIDATE_CONTEXT_CHARS=8000
MLX_VALIDATE_ANSWER_CHARS=1500
MLX_EMBED_TTL_SEC=300

# Validator backend: mlx — текущий рабочий валидатор, coreml — NLI/cross-encoder
# кандидат на Neural Engine, rules — безопасный deterministic fallback для тестов.
VALIDATOR_BACKEND=mlx
VALIDATOR_MODEL_VERSION=main
COREML_VALIDATOR_MODEL=artifacts/coreml/validator_minilm_l6_b1_s512.mlpackage
COREML_VALIDATOR_TOKENIZER=MoritzLaurer/multilingual-MiniLMv2-L6-mnli-xnli
COREML_VALIDATOR_VERSION=MoritzLaurer/multilingual-MiniLMv2-L6-mnli-xnli@validator_minilm_l6_b1_s512.mlpackage
COREML_VALIDATOR_SEQ_LEN=512
COREML_VALIDATOR_ATTENTION_MASK_RANK=4
COREML_VALIDATOR_COMPUTE_UNITS=cpu_only
COREML_VALIDATOR_CONTEXT_MODE=windows
COREML_VALIDATOR_PAIR_MODE=answer
COREML_VALIDATOR_ISOLATE_PROCESS=true
COREML_VALIDATOR_WORKER_TIMEOUT_SEC=60
COREML_VALIDATOR_MAX_FAILURES=2
COREML_VALIDATOR_FAILURE_COOLDOWN_SEC=300
COREML_VALIDATOR_LABELS=entailment,neutral,contradiction
COREML_VALIDATOR_MIN_CONFIDENCE=0.0
COREML_VALIDATOR_ENTAILMENT_THRESHOLD=0.8
COREML_VALIDATOR_CONTRADICTION_THRESHOLD=0.6
COREML_VALIDATOR_DECISION_MARGIN=0.05
COREML_VALIDATOR_LOCAL_FILES_ONLY=true
COREML_VALIDATOR_FALLBACK=false

# ── Эмбеддинги ───────────────────────────────────
# Qwen-профиль — текущий recommended default. Не смешивай embedding-модели
# в одной коллекции; для legacy BGE-M3 используй отдельную les_rag.
LES_EMBED_PROFILE=qwen
EMBED_MODEL=qwen3-embedding-0.6b
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# Backward compatibility: если EMBEDDING_MODEL не задан, mlx_host.py читает BGE_MODEL.
BGE_MODEL=BAAI/bge-m3
RAG_COLLECTION_NAME=les_rag_qwen3_06b
RAG_META_DB_PATH=./data/les_meta_qwen.db
RAG_VECTOR_SIZE=1024
BGE_BATCH_SIZE=8
RAG_EMBED_BATCH=16
RAG_CHUNK_SIZE=1400
RAG_CHUNK_OVERLAP=100
RAG_PARSE_POST_MAX_SWAP_PCT=60

# Core ML embedding backend. Requires `uv sync --group coreml` and a matching
# fixed-shape .mlpackage generated by tools/coreml_embedding_probe.py. Runtime
# keeps Core ML predict in an isolated worker process so a native CoreML crash
# cannot take down MLX Host. For Qwen b1_s1024, cpu_only returned zero vectors
# and cpu_and_ne crashed; cpu_and_gpu is the current guarded Core ML path.
EMBED_BACKEND=coreml
COREML_EMBED_MODEL=artifacts/coreml/qwen3_embedding_06b_b1_s512_static.mlpackage
COREML_EMBED_SEQ_LEN=1024
COREML_EMBED_BATCH_SIZE=1
COREML_EMBED_COMPUTE_UNITS=cpu_and_gpu
COREML_EMBED_ISOLATE_PROCESS=true
COREML_EMBED_WORKER_TIMEOUT_SEC=120
COREML_EMBED_MIN_NORM=0.5
COREML_EMBED_MAX_NORM=1.5
COREML_EMBED_MAX_FAILURES=2
COREML_EMBED_FAILURE_COOLDOWN_SEC=300
COREML_EMBED_LOCAL_FILES_ONLY=true
COREML_EMBED_FALLBACK=true

# Legacy BGE-M3 profile:
# LES_EMBED_PROFILE=legacy
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBED_MODEL=bge-m3
# RAG_COLLECTION_NAME=les_rag
# RAG_META_DB_PATH=./data/les_meta.db
# RAG_VECTOR_SIZE=1024
# RAG_CHUNK_SIZE=900
# RAG_CHUNK_OVERLAP=80

# ── URLs ─────────────────────────────────────────
# MLX Host для host-proxy. Docker proxy получает override из docker-compose.yml.
MLX_URL=http://127.0.0.1:8080

# External OpenAI-compatible providers. API keys are managed from GUI settings;
# keep defaults empty and do not commit real keys.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=
OPENROUTER_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_API_KEY=

# Speckle BIM/CAD bridge. Speckle may sleep; LES probes it with a short timeout.
SPECKLE_ENABLED=true
SPECKLE_BASE_URL=https://speckle.ovc.me
SPECKLE_GRAPHQL_URL=https://speckle.ovc.me/graphql
SPECKLE_API_TOKEN=
SPECKLE_WAKE_TIMEOUT_SEC=5

# Резерв через Ollama
# OLLAMA_URL=http://host.docker.internal:11434
# LLM_MODEL=qwen3:14b
# EMBED_MODEL=bge-m3:latest

# Qdrant local предпочитает host binary ~/.local/bin/qdrant; docker оставлен как fallback.
QDRANT_URL=http://127.0.0.1:6333
LES_QDRANT_RUNTIME=auto

# ── Безопасность ─────────────────────────────────
# JWT секрет (замени на случайную строку)
JWT_SECRET=change_me_to_random_string_32chars

# Пароль admin-ключа для В.О.Л.К.
# После первого запуска создаётся запись в auth_keys
ADMIN_PASSWORD=change_me_to_strong_password

# Trusted networks without API key. Keep loopback by default; add your VPN/LAN CIDR explicitly.
TRUSTED_NETWORKS=127.0.0.0/8,::1/128
TRUSTED_NETWORK_ROLE=admin
TRUSTED_PROXY_NETWORKS=127.0.0.0/8,::1/128
TRUSTED_PROXY_HEADER=x-les-trusted-network
# Example: TRUSTED_NETWORKS=127.0.0.0/8,::1/128,10.0.0.0/24
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8050,http://127.0.0.1:8050,http://localhost:8051,http://127.0.0.1:8051
LES_ENABLE_DOCKER_CONTROL=false
RAG_UPLOAD_SUFFIXES=.pdf,.docx,.doc,.eml,.emlx,.msg,.xlsx,.xls,.csv,.json,.jsonl,.md,.txt,.dwg,.rvt,.ifc,.ifczip
MAX_UPLOAD_MB=100
MAX_PST_UPLOAD_MB=2048
MAIL_IMAP_HOST=
MAIL_IMAP_PORT=993
MAIL_IMAP_SSL=true
MAIL_IMAP_LOGIN=
MAIL_IMAP_PASSWORD=
MAIL_IMAP_FOLDERS=INBOX
MAIL_IMAP_TIMEOUT_SEC=45
MAIL_IMAP_CHECKPOINT_DIR=data/mail_imap_checkpoints
MAIL_IMAP_STORAGE_ROOT=RAG_Content/MAIL/IMAP
MAIL_APPLE_ROOT=~/Library/Mail
MAIL_APPLE_STORAGE_ROOT=RAG_Content/MAIL/AppleMail
MAIL_ATTACHMENT_PDF_SUBPROCESS_ENABLED=true
MAIL_ATTACHMENT_PDF_TIMEOUT_SEC=30
MAIL_ATTACHMENT_PDF_MAX_PAGES=20
MAIL_ATTACHMENT_OCR_ENABLED=true
MAIL_TESSERACT_BIN=tesseract
MAIL_OCR_LANG=rus+eng
MAIL_ATTACHMENT_VLM_ENABLED=false
MAIL_VLM_URL=
MAIL_VLM_MODEL=
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.94
PDF_TABLE_EXTRACTION_ENABLED=false
PDF_TABLE_MAX_PAGES=30
PDF_TABLE_MAX_TABLES=50
DOCX_TABLE_EXTRACTION_ENABLED=false
DOCX_TABLE_MAX_TABLES=80
DOC_ROUTER_SAMPLE_PAGES=3
SOVUSHKA_STORAGE_SECRET=change_me_to_random_string_32chars
